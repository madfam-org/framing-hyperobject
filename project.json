{
  "project": {
    "name": "Framing Hyperobject",
    "slug": "framing-hyperobject",
    "version": "1.0.0",
    "description": {
      "en": "Parametric framing and containment systems (Hyperobject)\n\nOfficial Visualizer and Configurator: Yantra4D",
      "es": "Sistemas paramétricos de enmarcado y contención (Hiperobjeto)\n\nVisualizador y configurador oficial: Yantra4D"
    },
    "thumbnail": "docs/images/thumbnail.png",
    "tags": [
      "culture",
      "hyperobject",
      "commons",
      "framing",
      "display"
    ],
    "difficulty": "intermediate"
  },
  "modes": [
    {
      "id": "frame",
      "scad_file": "framing.scad",
      "cq_file": "framing.py",
      "label": {
        "en": "Frame Assembly",
        "es": "Ensamblaje del Marco"
      },
      "parts": [
        "frame_assembly",
        "back_panel",
        "glazing"
      ],
      "estimate": {
        "base_units": 1,
        "formula": "constant"
      }
    }
  ],
  "parts": [
    {
      "id": "frame_assembly",
      "render_mode": 0,
      "label": {
        "en": "Frame",
        "es": "Marco"
      },
      "default_color": "#8b4513"
    },
    {
      "id": "back_panel",
      "render_mode": 0,
      "label": {
        "en": "Backing",
        "es": "Respaldo"
      },
      "default_color": "#f5deb3"
    },
    {
      "id": "glazing",
      "render_mode": 0,
      "label": {
        "en": "Glazing",
        "es": "Vidrio/Acrílico"
      },
      "default_color": "#add8e6"
    }
  ],
  "parameters": [
    {
      "id": "target_material",
      "type": "select",
      "default": "polymaker-polylite-pla",
      "options": [
        {
          "value": "polymaker-polylite-pla",
          "label": "Polymaker PolyLite PLA"
        },
        {
          "value": "formlabs-clear-v4",
          "label": "Formlabs Clear V4"
        }
      ],
      "label": "Target Material",
      "hidden": true
    },
    {
      "id": "width",
      "type": "slider",
      "default": 200,
      "min": 50,
      "max": 1000,
      "step": 1,
      "label": {
        "en": "Width (mm)",
        "es": "Ancho (mm)"
      },
      "group": "dimensions"
    },
    {
      "id": "height",
      "type": "slider",
      "default": 250,
      "min": 50,
      "max": 1000,
      "step": 1,
      "label": {
        "en": "Height (mm)",
        "es": "Altura (mm)"
      },
      "group": "dimensions"
    },
    {
      "id": "depth",
      "type": "slider",
      "default": 20,
      "min": 10,
      "max": 100,
      "step": 1,
      "label": {
        "en": "Depth (mm)",
        "es": "Profundidad (mm)"
      },
      "group": "dimensions"
    },
    {
      "id": "profile_style",
      "type": "select",
      "default": "ogee",
      "options": [
        {
          "value": "ogee",
          "label": {
            "en": "Ogee (Classic)",
            "es": "Ogee (Clásico)"
          }
        },
        {
          "value": "bevel",
          "label": {
            "en": "Bevel",
            "es": "Biselado"
          }
        },
        {
          "value": "box",
          "label": {
            "en": "Box",
            "es": "Caja"
          }
        },
        {
          "value": "floater",
          "label": {
            "en": "Floater",
            "es": "Flotante"
          }
        },
        {
          "value": "stretcher",
          "label": {
            "en": "Stretcher Bar",
            "es": "Bastidor"
          }
        },
        {
          "value": "seg",
          "label": {
            "en": "SEG Extrusion",
            "es": "Perfil SEG"
          }
        },
        {
          "value": "snap",
          "label": {
            "en": "Snap Frame",
            "es": "Marco Snap"
          }
        }
      ],
      "label": {
        "en": "Profile Style",
        "es": "Estilo de Perfil"
      },
      "group": "style"
    },
    {
      "id": "mounting_style",
      "type": "select",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": {
            "en": "None",
            "es": "Ninguno"
          }
        },
        {
          "value": "vesa_75",
          "label": {
            "en": "VESA 75",
            "es": "VESA 75"
          }
        },
        {
          "value": "vesa_100",
          "label": {
            "en": "VESA 100",
            "es": "VESA 100"
          }
        },
        {
          "value": "french_cleat",
          "label": {
            "en": "French Cleat",
            "es": "Listón Francés"
          }
        },
        {
          "value": "standoffs",
          "label": {
            "en": "Standoffs",
            "es": "Separadores"
          }
        }
      ],
      "label": {
        "en": "Mounting",
        "es": "Montaje"
      },
      "group": "style"
    },
    {
      "id": "container_type",
      "type": "select",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": {
            "en": "None",
            "es": "Ninguno"
          }
        },
        {
          "value": "PSA",
          "label": {
            "en": "PSA Slab",
            "es": "Slab PSA"
          }
        },
        {
          "value": "BGS",
          "label": {
            "en": "BGS Slab",
            "es": "Slab BGS"
          }
        },
        {
          "value": "SGC",
          "label": {
            "en": "SGC Slab",
            "es": "Slab SGC"
          }
        },
        {
          "value": "CGC",
          "label": {
            "en": "CGC Slab",
            "es": "Slab CGC"
          }
        },
        {
          "value": "Silver Eagle",
          "label": {
            "en": "Silver Eagle Capsule",
            "es": "Cápsula Silver Eagle"
          }
        },
        {
          "value": "Small Dollar",
          "label": {
            "en": "Small Dollar Capsule",
            "es": "Cápsula Dólar Peq."
          }
        },
        {
          "value": "ID Badge",
          "label": {
            "en": "ID Badge (CR80)",
            "es": "Gafete (CR80)"
          }
        }
      ],
      "label": {
        "en": "Container",
        "es": "Contenedor"
      },
      "group": "containment"
    },
    {
      "id": "mat_width",
      "type": "slider",
      "default": 50,
      "min": 0,
      "max": 200,
      "step": 1,
      "label": {
        "en": "Mat Width (mm)",
        "es": "Ancho Paspartú (mm)"
      },
      "group": "components"
    },
    {
      "id": "glazing_thickness",
      "type": "slider",
      "default": 2,
      "min": 1,
      "max": 6,
      "step": 0.5,
      "label": {
        "en": "Glazing Thickness (mm)",
        "es": "Grosor Vidrio (mm)"
      },
      "group": "components"
    }
  ],
  "estimate_constants": {
    "base_time": 5,
    "per_unit": 1,
    "per_part": 8
  },
  "export_formats": [
    "stl",
    "3mf",
    "off",
    "step",
    "glb",
    "gltf",
    "obj"
  ],
  "hyperobject": {
    "domain": "infrastructure",
    "cdg_interfaces": [
      {
        "id": "rabbet_joint",
        "label": {
          "en": "Rabbet Joint",
          "es": "Junta de Rebaje"
        },
        "geometry_type": "pocket",
        "standard": "internal",
        "parameters": [
          "mat_width",
          "glazing_thickness"
        ]
      },
      {
        "id": "seg_channel",
        "label": {
          "en": "T-Slot Extrusion Channel",
          "es": "Canal de Extrusión en T"
        },
        "geometry_type": "profile",
        "standard": "internal",
        "parameters": []
      },
      {
        "id": "snap_profile",
        "label": {
          "en": "Snap-Fit Interface",
          "es": "Interfaz de Encaje"
        },
        "geometry_type": "snap",
        "standard": "internal",
        "parameters": []
      },
      {
        "id": "vesa_pattern",
        "label": {
          "en": "VESA Mount Pattern",
          "es": "Patrón de Montaje VESA"
        },
        "geometry_type": "bolt_pattern",
        "standard": "VESA 75/100",
        "parameters": [
          "mounting_style"
        ]
      },
      {
        "id": "french_cleat",
        "label": {
          "en": "French Cleat Profile",
          "es": "Perfil de Listón Francés"
        },
        "geometry_type": "profile",
        "standard": "internal",
        "parameters": [
          "mounting_style"
        ]
      },
      {
        "id": "standoff_bore",
        "label": {
          "en": "Threaded Standoff",
          "es": "Separador Roscado"
        },
        "geometry_type": "socket",
        "standard": "internal",
        "parameters": [
          "mounting_style"
        ]
      }
    ],
    "material_awareness": {
      "shrinkage_compensation": false,
      "recycled_material_toggle": false,
      "tolerance_by_material": false
    },
    "societal_benefit": {
      "en": "Modular framing and containment systems enable reuse via standardized mechanical interfaces",
      "es": "Los sistemas modulares de enmarcado y contención permiten la reutilización mediante interfaces mecánicas estandarizadas"
    },
    "commons_license": "CERN-OHL-W-2.0"
  }
}
